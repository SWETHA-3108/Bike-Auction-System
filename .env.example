# Copy to backend/.env and frontend/.env (see README)

# Backend
NODE_ENV=development
PORT=3001
MONGODB_URI=mongodb://localhost:27017/bike_auction
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_REFRESH_SECRET=change-me-to-another-random-string-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# Frontend (frontend/.env)
VITE_API_URL=http://localhost:3001/v1
VITE_SOCKET_URL=http://localhost:3001
